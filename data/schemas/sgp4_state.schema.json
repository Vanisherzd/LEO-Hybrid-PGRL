{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leo-hybrid-pgrl/schemas/sgp4_state.schema.json",
  "title": "SGP4 Derived State",
  "description": "A single SGP4/SDP4 propagated state with derived Doppler/geodetic features. Simulation/offline feature record; not measured RF evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "norad_id",
    "epoch_utc",
    "query_time_utc",
    "dt_since_epoch_s",
    "x_m", "y_m", "z_m",
    "vx_mps", "vy_mps", "vz_mps",
    "latitude_deg", "longitude_deg", "altitude_m",
    "radial_velocity_mps",
    "doppler_hz",
    "doppler_rate_hz_per_s",
    "source_tle_epoch_utc",
    "generator_version"
  ],
  "properties": {
    "sample_id": { "type": "string", "description": "Unique sample identifier." },
    "norad_id": { "type": "integer", "minimum": 1, "description": "NORAD catalog number of the source TLE." },
    "epoch_utc": { "type": "string", "format": "date-time", "description": "Reference epoch (UTC)." },
    "query_time_utc": { "type": "string", "format": "date-time", "description": "Time at which the state was evaluated (UTC)." },
    "dt_since_epoch_s": { "type": "number", "description": "Seconds between source TLE epoch and query time." },
    "x_m": { "type": "number", "description": "ECI/ECEF X position (m)." },
    "y_m": { "type": "number", "description": "ECI/ECEF Y position (m)." },
    "z_m": { "type": "number", "description": "ECI/ECEF Z position (m)." },
    "vx_mps": { "type": "number", "description": "X velocity (m/s)." },
    "vy_mps": { "type": "number", "description": "Y velocity (m/s)." },
    "vz_mps": { "type": "number", "description": "Z velocity (m/s)." },
    "latitude_deg": { "type": "number", "minimum": -90, "maximum": 90, "description": "Sub-satellite latitude (deg)." },
    "longitude_deg": { "type": "number", "minimum": -180, "maximum": 180, "description": "Sub-satellite longitude (deg)." },
    "altitude_m": { "type": "number", "description": "Altitude above reference ellipsoid (m)." },
    "radial_velocity_mps": { "type": "number", "description": "Radial velocity relative to the ground station (m/s; positive = receding)." },
    "doppler_hz": { "type": "number", "description": "Predicted Doppler shift at the carrier (Hz)." },
    "doppler_rate_hz_per_s": { "type": "number", "description": "Predicted Doppler rate (Hz/s)." },
    "source_tle_epoch_utc": { "type": "string", "format": "date-time", "description": "Epoch of the TLE used to generate this state (UTC)." },
    "generator_version": { "type": "string", "description": "Version tag of the SGP4 feature generator." }
  }
}
